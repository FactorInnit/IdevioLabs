generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                           String   @id @default(cuid())
  email                        String   @unique
  name                         String
  passwordHash                 String?
  googleId                     String?  @unique
  googleCalendarRefreshToken   String?
  googleCalendarEmail          String?
  plan                         String   @default("free")
  stripeCustomerId             String?
  stripeSubscriptionId         String?
  createdAt                    DateTime @default(now())

  projects                     Project[]
  projectMemberships           ProjectMember[]
  sentProjectInvites           ProjectInvite[] @relation("InvitedBy")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("editor")
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

model ProjectInvite {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  email       String
  role        String   @default("editor")
  token       String   @unique
  invitedById String
  invitedBy   User     @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  status      String   @default("pending")
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@unique([projectId, email])
}

model Project {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  prompt       String
  description  String?
  budget       Float?
  budgetNotes  String?
  status       String   @default("planning")
  progress     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  nodes        WorkflowNode[]
  edges        WorkflowEdge[]
  reminders    Reminder[]
  progressLogs ProgressLog[]
  teamMessages TeamMessage[]
  members      ProjectMember[]
  invites      ProjectInvite[]
}

model TeamMessage {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String?
  userName  String
  message   String
  createdAt DateTime @default(now())
}

model WorkflowNode {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category      String
  title         String
  description   String
  tools         String
  tasks         String
  status        String   @default("pending")
  progress      Int      @default(0)
  posX          Float
  posY          Float
  estimatedCost Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  progressLogs  ProgressLog[]
}

model WorkflowEdge {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceId  String
  targetId  String
}

model Reminder {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  message   String
  time      String
  days      String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model ProgressLog {
  id        String        @id @default(cuid())
  projectId String
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  nodeId    String?
  node      WorkflowNode? @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  note      String
  createdAt DateTime      @default(now())
}
